{
  "name": "ssh-mcp-universal",
  "version": "3.2.2",
  "description": "SSH MCP Universal: Model Context Protocol server for SSH remote server management. Control SSH connections from Claude Code and OpenAI Codex - execute commands, transfer files, database operations, backups, health monitoring, and DevOps automation. NEW: Tool activation system reduces context usage by 92%",
  "main": "src/index.js",
  "bin": {
    "ssh-mcp-universal": "src/index.js",
    "mcp-ssh-manager": "src/index.js",
    "ssh-manager": "cli/ssh-manager",
    "ssh-manager-dashboard": "src/dashboard-main.js"
  },
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dashboard:start": "node src/dashboard-main.js",
    "setup": "npm install && pip install -r tools/requirements.txt",
    "configure": "python tools/server-manager.py",
    "test-connection": "python tools/test-connection.py",
    "test": "npm run test:profiles && npm run test:aliases && npm run test:hooks && npm run test:tools && npm run test:config-loader && npm run test:tool-config-manager && npm run test:web-ui-helpers && npm run test:web-ui-services && npm run test:dashboard-service && npm run test:ssh-key-manager && npm run test:web-ui-server",
    "test:profiles": "node tests/test-profiles.js",
    "test:aliases": "node tests/test-command-aliases.js",
    "test:hooks": "node tests/test-hooks.js",
    "test:tools": "node tests/test-tool-registry.js",
    "test:config-loader": "node tests/test-config-loader.js",
    "test:tool-config-manager": "node tests/test-tool-config-manager.js",
    "test:web-ui-helpers": "node tests/test-web-ui-helpers.js",
    "test:web-ui-services": "node tests/test-web-ui-services.js",
    "test:dashboard-service": "node tests/test-dashboard-service.js",
    "test:ssh-key-manager": "node tests/test-ssh-key-manager.js",
    "test:web-ui-server": "node tests/test-web-ui-server.js",
    "test:sprint": "npm run test:web-ui-helpers && npm run test:web-ui-services && npm run test:dashboard-service && npm run test:web-ui-server",
    "test:coverage": "c8 --reporter=text --reporter=lcov npm test",
    "test:coverage:sprint": "c8 --all --check-coverage --lines 100 --statements 100 --reporter=text --include=src/web-ui-content.js --include=src/web-ui-helpers.js --include=src/web-ui-services.js --include=src/web-ui-server.js --include=src/dashboard-service.js npm run test:sprint",
    "test:all": "npm test && ./scripts/validate.sh",
    "validate": "./scripts/validate.sh",
    "lint": "eslint src/*.js",
    "format": "prettier --write 'src/**/*.js' 'tests/**/*.js'"
  },
  "keywords": [
    "mcp",
    "ssh",
    "mcp-ssh",
    "mcp ssh",
    "ssh-mcp",
    "ssh mcp",
    "model-context-protocol-ssh",
    "mcp-server",
    "mcp server ssh",
    "claude-code",
    "claude-ssh",
    "claude-code-ssh",
    "openai-codex",
    "codex",
    "model-context-protocol",
    "remote-server",
    "ssh-manager",
    "ssh manager mcp",
    "remote-ssh",
    "ssh-automation",
    "deployment",
    "devops",
    "automation",
    "backup",
    "restore",
    "health-monitoring",
    "database",
    "mysql",
    "postgresql",
    "mongodb",
    "profiles",
    "hooks",
    "aliases",
    "toml",
    "ai-assistant",
    "ai-tools",
    "llm-tools"
  ],
  "author": "AlekseiSeleznev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlekseiSeleznev/ssh-mcp-universal.git"
  },
  "bugs": {
    "url": "https://github.com/AlekseiSeleznev/ssh-mcp-universal/issues"
  },
  "homepage": "https://github.com/AlekseiSeleznev/ssh-mcp-universal#readme",
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "^1.17.2",
    "dotenv": "^16.4.5",
    "ssh2": "^1.17.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "c8": "^10.1.2",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
