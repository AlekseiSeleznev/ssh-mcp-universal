        "mcp__ssh-universal__ssh_tunnel_close",
        "mcp__ssh-universal__ssh_session_start",
        "mcp__ssh-universal__ssh_session_send",
        "mcp__ssh-universal__ssh_session_list",
        "mcp__ssh-universal__ssh_session_close",
        "mcp__ssh-universal__ssh_execute_group",
        "mcp__ssh-universal__ssh_group_manage",
        "mcp__ssh-universal__ssh_tail",
